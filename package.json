{
  "name": "aidusia-studio",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/inject-precache.mjs",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/test-otsu.mjs && node scripts/test-throttle.mjs",
    "e2e": "npm run build && npm run e2e:run:desktop && npm run e2e:run:mobile",
    "e2e:desktop": "npm run build && npm run e2e:run:desktop",
    "e2e:mobile": "npm run build && npm run e2e:run:mobile",
    "e2e:run:desktop": "node scripts/run-e2e.mjs chromium",
    "e2e:run:mobile": "node scripts/run-e2e.mjs mobile",
    "preview": "vite preview",
    "brand-scan": "node scripts/brand-isolation-scan.mjs",
    "security:audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.3.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.3.0",
    "@mlc-ai/web-llm": "^0.2.84",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.74.0",
    "tailwindcss": "^4.3.2",
    "typescript": "5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
